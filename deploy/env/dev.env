# Development environment — copy to project root as .env or use: make up ENV=dev

APP_ENV=dev

POSTGRES_USER=food
POSTGRES_PASSWORD=food
POSTGRES_DB=food_platform
POSTGRES_SSLMODE=disable

JWT_SECRET=dev-secret-change-me
JWT_TTL=24h

KAFKA_BROKERS=kafka:9092

# OpenTelemetry → Jaeger (leave empty to disable tracing)
OTEL_EXPORTER_OTLP_ENDPOINT=jaeger:4317
OTEL_TRACES_SAMPLER_ARG=1.0

USER_SVC_URL=http://user-svc:8081
RESTAURANT_SVC_URL=http://restaurant-svc:8082
ORDER_SVC_URL=http://order-svc:8083
PAYMENT_SVC_URL=http://payment-svc:8084
DELIVERY_SVC_URL=http://delivery-svc:8085

PAYMENT_FAIL_RATE=0.0
PAYMENT_PROCESS_LATENCY=500ms
PAYMENT_REFUND_LATENCY=300ms
PAYMENT_METHOD=card

KITCHEN_COOK_DURATION=3s
KITCHEN_FAIL_RATE=0.0

DELIVERY_DURATION=5s

SEED_DATA=true

CORS_ALLOWED_ORIGINS=*

NEXT_PUBLIC_API_URL=http://localhost:8090
