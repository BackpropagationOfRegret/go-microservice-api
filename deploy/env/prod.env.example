# Production — copy to deploy/env/prod.env and fill secrets (never commit real secrets)

APP_ENV=prod

POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=food_platform
POSTGRES_SSLMODE=require

JWT_SECRET=
JWT_TTL=8h

KAFKA_BROKERS=kafka:9092

USER_SVC_URL=http://user-svc:8081
RESTAURANT_SVC_URL=http://restaurant-svc:8082
ORDER_SVC_URL=http://order-svc:8083
PAYMENT_SVC_URL=http://payment-svc:8084
DELIVERY_SVC_URL=http://delivery-svc:8085

PAYMENT_FAIL_RATE=0.0
PAYMENT_PROCESS_LATENCY=500ms
PAYMENT_REFUND_LATENCY=2s
PAYMENT_METHOD=card

KITCHEN_COOK_DURATION=15m
KITCHEN_FAIL_RATE=0.0

DELIVERY_DURATION=30m

SEED_DATA=false

CORS_ALLOWED_ORIGINS=https://app.example.com

NEXT_PUBLIC_API_URL=https://api.example.com
